# ===========================================
# KAI Finder - Backend Environment Variables
# ===========================================

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/kai_finder?schema=public"

# JWT Secret (generate dengan: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# JWT Expiry
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:3000

# Upload Settings
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# ===========================================
# Cloudflare R2 Configuration
# ===========================================
# R2 is S3-compatible storage for images
# Get these from Cloudflare Dashboard > R2 > Manage Buckets

# Account ID from Cloudflare Dashboard
R2_ACCOUNT_ID=your-cloudflare-account-id

# API Token (create in Cloudflare > My Profile > API Tokens)
# Needs: Edit Cloudflare Workers template or custom token with R2 permissions
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Bucket name you created
R2_BUCKET_NAME=kai-finder-fotos

# Optional: Custom domain for R2 (if configured)
# R2_PUBLIC_URL=https://cdn.yourdomain.com

# ===========================================
# QR Code API
# ===========================================
QR_CODE_API_URL=http://localhost:5000/api/qr
